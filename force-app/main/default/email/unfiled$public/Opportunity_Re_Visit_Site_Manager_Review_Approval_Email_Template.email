	<li><span style="font-family:Times New Roman,Times New Roman,Times,serif;"><span style="font-size:16px;">Site Visit Supervisor:&nbsp;<strong>{{{Site_Visit_Report__c.Supervisor_User__r.Name}}}</strong></span></span></li>
	<li><span style="font-family:Times New Roman,Times New Roman,Times,serif;"><span style="font-size:16px;">Site Visit Date:&nbsp;<strong>{{{Site_Visit_Report__c.Site_Visit_Date__c}}}</strong></span></span></li>
	<li><span style="font-family:Times New Roman,Times New Roman,Times,serif;"><span style="font-size:16px;">Site Visit Time Slot:&nbsp;<strong>{{{Site_Visit_Report__c.Site_Visit_Time_Slot__c}}}</strong></span></span></li>
	<li><span style="font-family:Times New Roman,Times New Roman,Times,serif;"><span style="font-size:16px;">Estimated Completion Months:&nbsp;<strong>{{{Site_Visit_Report__c.Estimated_Completion_Months__c}}}</strong></span></span></li>
	<li><span style="font-family:Times New Roman,Times New Roman,Times,serif;"><span style="font-size:16px;">Supervisor Finall Estimated&nbsp;Cost: <strong>{{{Site_Visit_Report__c.Total_Estimated_Cost__c}}}</strong></span></span></li>
	<li><span style="font-family:Times New Roman,Times New Roman,Times,serif;"><span style="font-size:16px;">Site Visit Report Status: <strong>{{{Site_Visit_Report__c.Site_Visit_Report_Status__c}}}</strong></span></span></li>
