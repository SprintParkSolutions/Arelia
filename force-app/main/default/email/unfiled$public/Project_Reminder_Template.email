	<li><span style="font-family:Arial,Helvetica,sans-serif;">&nbsp;<strong>Client:</strong> {{ClientName}}</span></li>
	<li><span style="font-family:Arial,Helvetica,sans-serif;">&nbsp;<strong>Completion Status:</strong> {{CompletionStatus}}</span></li>
	<li><span style="font-family:Arial,Helvetica,sans-serif;">&nbsp;<strong>Type of Project: </strong>{{TypeOfProject}}</span></li>
	<li><span style="font-family:Arial,Helvetica,sans-serif;">&nbsp;<strong>Start Date:</strong> {{StartDate}}</span></li>
