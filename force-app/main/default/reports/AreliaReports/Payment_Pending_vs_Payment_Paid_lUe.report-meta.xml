    <columns>
        <field>CUST_NAME</field>
    </columns>
    <columns>
        <field>Payment_Term__c.Payment_Status__c</field>
    </columns>
    <columns>
        <field>Payment_Term__c.Due_Date__c</field>
    </columns>
    <columns>
        <field>CDF1</field>
    </columns>
    <customDetailFormulas>
        <calculatedFormula>IF(
    Payment_Term__c.Payment_Status__c = &quot;Paid&quot;,
    &quot;Payment Completed&quot;,
    IF(
        Payment_Term__c.Due_Date__c = TODAY(),
        &quot;Due Today&quot;,
        IF(
            Payment_Term__c.Due_Date__c &gt; TODAY(),
            TEXT(Payment_Term__c.Due_Date__c - TODAY()) &amp; &quot; days left&quot;,
            &quot;Overdue by &quot; &amp; TEXT(TODAY() - Payment_Term__c.Due_Date__c) &amp; &quot; days&quot;
        )
    )
)</calculatedFormula>
        <dataType>Text</dataType>
        <developerName>CDF1</developerName>
        <label>Payment Due Status</label>
        <scale>2</scale>
    </customDetailFormulas>
    <format>Summary</format>
    <groupingsDown>
        <dateGranularity>Day</dateGranularity>
        <field>FK_NAME</field>
        <sortOrder>Asc</sortOrder>
    </groupingsDown>
    <name>Payment Pending vs Payment Paid</name>
    <params>
        <name>co</name>
        <value>1</value>
    </params>
    <reportType>CustomEntity$Payment_Term__c@Payment_Term__c.Project__c</reportType>
    <scope>user</scope>
