<apex:page standardController="Project_Expense_Sheet__c" renderAs="pdf" applyBodyTag="false">
    <head>
        <style>
            @page {
                size: A4;
                margin: 1cm;
            }
            body {
                font-family: 'Arial Unicode MS'; /* Crucial for ₹ symbol */
                font-size: 11px;
                color: #333;
            }
            .header-box {
                width: 100%;
                margin-bottom: 30px;
            }
            .title {
                font-size: 24px;
                font-weight: bold;
                color: #000;
                text-transform: uppercase;
            }
            .subtitle {
                font-size: 14px;
                color: #666;
                margin-top: 5px;
            }
            
            /* Project Details Box */
            .project-info {
                width: 100%;
                margin-bottom: 25px;
                border: 1px solid #ccc;
                padding: 10px;
                background-color: #f9f9f9;
            }
            .info-row {
                width: 100%;
                margin-bottom: 5px;
            }
            .info-label {
                font-weight: bold;
                color: #555;
                display: inline-block;
                width: 120px;
            }
            .info-val {
                display: inline-block;
            }

            /* Tables */
            .section-header {
                font-size: 14px;
                font-weight: bold;
                background-color: #005fb2; /* Arelia Blue Color */
                color: white;
                padding: 5px 10px;
                margin-top: 20px;
                margin-bottom: 0;
            }
            
            table {
                width: 100%;
                border-collapse: collapse;
                margin-bottom: 10px;
            }
            th {
                background-color: #e6e6e6;
                color: #000;
                font-weight: bold;
                padding: 8px;
                border: 1px solid #ccc;
                text-align: left;
            }
            td {
                padding: 8px;
                border: 1px solid #ccc;
                vertical-align: top;
            }
            .text-right {
                text-align: right;
            }
            .grand-total-box {
                margin-top: 20px;
                text-align: right;
                font-size: 16px;
                font-weight: bold;
                background-color: #f2f2f2;
                padding: 10px;
                border: 1px solid #ccc;
            }
        </style>
    </head>
    
    <div class="header-box">
        <div class="title">Arelia Living</div>
        <div class="subtitle">Expense Report</div>
        <div style="margin-top:5px;">Date: <apex:outputText value="{0,date,dd/MM/yyyy}"><apex:param value="{!Project_Expense_Sheet__c.Sheet_Date__c}"/></apex:outputText></div>
    </div>

    <div class="project-info">
        <table style="border:none; margin:0;">
            <tr style="background-color:transparent;">
                <td style="border:none; width:50%;">
                    <div class="info-row"><span class="info-label">Project Name:</span> <span class="info-val">{!Project_Expense_Sheet__c.Project__r.Name}</span></div>
                    <div class="info-row"><span class="info-label">Project Code:</span> <span class="info-val">{!Project_Expense_Sheet__c.Project__r.Project_Code__c}</span></div>
                    <div class="info-row"><span class="info-label">Client Name:</span> <span class="info-val">{!Project_Expense_Sheet__c.Project__r.Client__r.Name}</span></div>
                </td>
                <td style="border:none; width:50%;">
                    <div class="info-row"><span class="info-label">Site Location:</span> <span class="info-val">{!Project_Expense_Sheet__c.Project__r.Site_Location__c}</span></div>
                    <div class="info-row"><span class="info-label">Status:</span> <span class="info-val">{!Project_Expense_Sheet__c.Project__r.Project_Status__c}</span></div>
                </td>
            </tr>
        </table>
    </div>
    
    <div class="section-header">Material Items</div>
    <table>
        <thead>
            <tr>
                <th style="width: 20%;">Item Name</th>
                <th style="width: 25%;">Description</th>
                <th style="width: 15%;">Brand</th>
                <th style="width: 10%; text-align:right;">Qty</th>
                <th style="width: 15%; text-align:right;">Rate</th>
                <th style="width: 15%; text-align:right;">Amount</th>
            </tr>
        </thead>
        <tbody>
            <apex:repeat value="{!Project_Expense_Sheet__c.Expense_Line_Items__r}" var="line">
                <apex:outputPanel layout="none" rendered="{!line.Type__c == 'Material'}">
                    <tr>
                        <td>{!line.Item_Name__c}</td>
                        <td>{!line.Description__c}</td>
                        <td>{!line.Brand__c}</td>
                        <td class="text-right">
                            <apex:outputText value="{0, number, 0.0}"><apex:param value="{!line.Quantity__c}"/></apex:outputText>
                        </td>
                        <td class="text-right">
                            <apex:outputText value="₹ {0, number, ###,###,##0.00}"><apex:param value="{!line.Rate__c}"/></apex:outputText>
                        </td>
                        <td class="text-right">
                            <apex:outputText value="₹ {0, number, ###,###,##0.00}"><apex:param value="{!line.Amount__c}"/></apex:outputText>
                        </td>
                    </tr>
                </apex:outputPanel>
            </apex:repeat>
        </tbody>
    </table>

    <div class="section-header">Other Expenses</div>
    <table>
        <thead>
            <tr>
                <th style="width: 80%;">Description</th>
                <th style="width: 20%; text-align:right;">Amount</th>
            </tr>
        </thead>
        <tbody>
            <apex:repeat value="{!Project_Expense_Sheet__c.Expense_Line_Items__r}" var="line">
                <apex:outputPanel layout="none" rendered="{!line.Type__c == 'Other'}">
                    <tr>
                        <td>{!line.Description__c}</td>
                        <td class="text-right">
                            <apex:outputText value="₹ {0, number, ###,###,##0.00}"><apex:param value="{!line.Amount__c}"/></apex:outputText>
                        </td>
                    </tr>
                </apex:outputPanel>
            </apex:repeat>
        </tbody>
    </table>

    <div class="grand-total-box">
        Grand Total: 
        <apex:outputText value="₹ {0, number, ###,###,##0.00}">
            <apex:param value="{!Project_Expense_Sheet__c.Grand_Total__c}"/>
        </apex:outputText>
    </div>
</apex:page>