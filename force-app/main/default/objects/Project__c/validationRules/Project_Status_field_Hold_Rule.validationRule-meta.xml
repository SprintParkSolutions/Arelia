<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Project_Status_field_Hold_Rule</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISPICKVAL(Status__c, &quot;Hold&quot;),
    ISBLANK(TEXT(Hold_Reason__c))
)</errorConditionFormula>
    <errorDisplayField>Hold_Reason__c</errorDisplayField>
    <errorMessage>Hold Reason is required when Status is set to Hold.</errorMessage>
</ValidationRule>
