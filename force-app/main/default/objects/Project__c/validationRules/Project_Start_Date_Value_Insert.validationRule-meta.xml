<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Project_Start_Date_Value_Insert</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISPICKVAL(Status__c, &quot;Initiated&quot;),
    NOT(ISBLANK(Start_Date__c))
)</errorConditionFormula>
    <errorMessage>Start Date cannot be entered when Status is on Initiated</errorMessage>
</ValidationRule>
