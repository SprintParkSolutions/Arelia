<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Past_Vendor_Work_End_Date_Rule</fullName>
    <active>true</active>
    <errorConditionFormula>Vendor_Work_End_Date__c &lt;  Vendor_Work_Start_Date__c</errorConditionFormula>
    <errorMessage>Vendor Work End Date cannot be less than Vendor Work Start Date.</errorMessage>
</ValidationRule>
