<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Past_Vendor_Work_Start_Date_Rule</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    ISNEW(),
     Vendor_Work_Start_Date__c &lt; TODAY()
)</errorConditionFormula>
    <errorMessage>Vendor Work Start Date cannot be in the past</errorMessage>
</ValidationRule>
