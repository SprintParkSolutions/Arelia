<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Site_Visit_Report_Creation</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
    NOT(ISBLANK(Lead__c)),
    NOT(Lead__r.Appointment_Completed__c)
)</errorConditionFormula>
    <errorMessage>You cannot create or edit a Site Visit Report for a Lead unless Appointment Confirmed is checked.</errorMessage>
</ValidationRule>
